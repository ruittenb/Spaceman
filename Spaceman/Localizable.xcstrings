    "Error: %@\n\nPlease grant %@ permissions to Spaceman in %@ → Privacy and Security." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fehler: %1$@\n\nBitte gewähre Spaceman %2$@-Berechtigungen in %3$@ → Datenschutz & Sicherheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Error: %1$@\n\nPlease grant %2$@ permissions to Spaceman in %3$@ → Privacy and Security."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Error: %1$@\n\nPor favor, otorga permisos de %2$@ a Spaceman en %3$@ → Privacidad y seguridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erreur : %1$@\n\nVeuillez accorder les autorisations %2$@ à Spaceman dans %3$@ → Confidentialité et sécurité."
