    "For switching between spaces to work, these settings must match the keyboard shortcuts assigned for Mission Control." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit der Wechsel zwischen Spaces funktioniert, müssen diese Einstellungen mit den Tastaturkurzbefehlen für Mission Control übereinstimmen."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para que el cambio entre espacios funcione, estas configuraciones deben coincidir con las funciones rápidas de teclado asignadas a Mission Control."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour que le changement d'espace fonctionne, ces réglages doivent correspondre aux raccourcis clavier attribués à Mission Control."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om succesvol te kunnen wisselen tussen spaces, moeten deze instellingen overeenkomen met de sneltoetsen die zijn toegewezen in Mission Control."
          }
        }
      }
    },
